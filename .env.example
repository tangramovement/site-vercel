# GitHub OAuth app. Configure its callback as https://www.tangramovement.com/api/callback.
TANGRAM_OAUTH_CLIENT_ID=
TANGRAM_OAUTH_CLIENT_SECRET=
TANGRAM_OAUTH_CALLBACK_URL=https://www.tangramovement.com/api/callback
TANGRAM_ADMIN_ORIGINS=https://www.tangramovement.com

# Resend email delivery for the public contact form.
RESEND_API_KEY=
CONTACT_SENDER=Tangram <contact@your-verified-domain.example>
CONTACT_RECIPIENT=tangramovement@gmail.com
